{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user" },
        "email": { "type": "string", "format": "email", "description": "The user's email address" },
        "displayName": { "type": "string", "description": "The user's display name" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created" }
      },
      "required": ["uid", "email"]
    },
    "DashboardData": {
      "title": "DashboardData",
      "description": "Data displayed on the user's dashboard",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who owns this data" },
        "content": { "type": "string", "description": "The content of the dashboard item" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the data was last updated" }
      },
      "required": ["userId", "content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile information"
    },
    "/dashboard/{dataId}": {
      "schema": "DashboardData",
      "description": "User-specific dashboard data"
    }
  }
}
